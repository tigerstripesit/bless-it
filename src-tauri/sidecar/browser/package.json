{
  "name": "ittoolkit-browser-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/bundle.cjs",
    "package": "node scripts/build-sidecar.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "install-chromium": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "playwright-core": "1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
